[Unit]
Description=AgnoCon .NET Web API
After=network.target

[Service]
WorkingDirectory=/var/www/agnocon
ExecStart=/usr/bin/dotnet /var/www/agnocon/AgnoCon.dll
Restart=always
RestartSec=10
KillSignal=SIGINT
SyslogIdentifier=agnocon

Environment=ASPNETCORE_ENVIRONMENT=Production
Environment=ASPNETCORE_URLS=http://127.0.0.1:5000
Environment=DOTNET_PRINT_TELEMETRY_MESSAGE=false

[Install]
WantedBy=multi-user.target
